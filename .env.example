NETWORKQUALITY_BACKEND_URL=http://localhost:8080
NETWORKQUALITY_ADMIN_TOKEN=dev-admin-token-change-me

# Dashboard HTTP Basic Auth — the dashboard refuses to serve unless
# NETWORKQUALITY_DASHBOARD_PASSWORD is set. USER defaults to "admin".
NETWORKQUALITY_DASHBOARD_USER=admin
NETWORKQUALITY_DASHBOARD_PASSWORD=dev-dashboard-password-change-me
